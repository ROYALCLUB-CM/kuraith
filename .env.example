# KURAITH Server Configuration
PORT=47700
HOST=0.0.0.0

# Database
DATABASE_URL="postgresql://kuraith:kuraith_password@localhost:5432/kuraith?schema=public"

# JWT
JWT_SECRET="change-this-to-a-random-secret"
JWT_EXPIRES_IN="7d"

# Embeddings (for vector search)
# Option 1: OpenAI
OPENAI_API_KEY="sk-xxx"
# Option 2: Local model (future)
# EMBEDDING_MODEL="local"

# Telegram Notifications (optional)
# Create bot via @BotFather, get chat_id from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Dashboard
DASHBOARD_PORT=3000
